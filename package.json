{
	"name": "server-monitor",
	"displayName": "Server Monitor",
	"description": "Adicione e monitore seus servidores dentro do VsCode.",
	"version": "1.0.1",
	"publisher": "HeygonLago",
	"author": {
		"name": "Heygon Lago",
		"email": "heygon@m42.com.br"
	},
	"engines": {
		"vscode": "^1.49.0"
	},
	"license": "MIT",
	"homepage": "https://github.com/EduardoPires/vscode-status-bar-custom-item",
	"repository": {
		"type": "git",
		"url": "https://github.com/EduardoPires/vscode-status-bar-custom-item.git"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"statusbar",
		"status",
		"custom",
		"item",
		"personalize",
		"customizer",
		"personal"
	],
	"activationEvents": [
		"*"
	],
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint src --ext ts",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^7.1.3",
		"@types/minimatch": "5.1.2",
		"@types/mocha": "^8.0.0",
		"@types/node": "^12.11.7",
		"@types/ssh2": "^1.15.0",
		"@types/vscode": "^1.49.0",
		"@typescript-eslint/eslint-plugin": "^4.1.1",
		"@typescript-eslint/parser": "^4.1.1",
		"eslint": "^7.9.0",
		"glob": "^7.1.6",
		"mocha": "^8.1.3",
		"typescript": "^4.0.2",
		"vscode-test": "^1.4.0"
	},
	"dependencies": {
		"@vscode/test-electron": "^2.1.3",
		"ssh2": "^1.16.0"
	},
	"contributes": {
		"commands": [
			{
				"command": "monitor.openDashboard",
				"title": "Server Monitor: Open Dashboard"
			}
		],
		"configuration": {
			"title": "Server Monitor Dashboard",
			"properties": {
				"serverMonitor.dashboard.text": {
					"type": "string",
					"default": "",
					"description": "Texto exibido na barra de status para o monitor base."
				},
				"serverMonitor.dashboard.tooltip": {
					"type": "string",
					"default": "Acesse seu painel online/offline",
					"description": "Texto do tooltip na barra de status."
				},
				"serverMonitor.dashboard.icon": {
					"type": "string",
					"default": "⛈️",
					"description": "Ícone para o monitor na barra de status."
				}
			}
		}
	}
}